rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
       return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isSignedIn() {
       return request.auth != null; // Notice: skipping email_verified for simpler google auth setup
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    // Zero-knowledge storage: every synced document is an opaque AES-GCM
    // blob encrypted client-side with a key derived from the master
    // password. The server never sees plaintext.
    //
    // hasOnly() is the important part — it REJECTS any write containing
    // plaintext vault fields (title, password, totpSecret, ...), so an
    // outdated or misbehaving client cannot accidentally leak secrets
    // into Firestore.
    function isValidBlobDoc(data) {
       return data.keys().hasAll(['blob', 'userId'])
         && data.keys().hasOnly(['blob', 'userId', 'updatedAt'])
         && data.blob is string && data.blob.size() > 0 && data.blob.size() <= 300000
         && data.userId is string && data.userId == request.auth.uid
         && (!("updatedAt" in data) || data.updatedAt is number);
    }

    function isValidUserSettings(data) {
       return (!("clipboardClearTimeoutSeconds" in data) || data.clipboardClearTimeoutSeconds is number)
         && (!("theme" in data) || (data.theme is string && data.theme.size() <= 32))
         && (!("masterPasswordSet" in data) || data.masterPasswordSet is bool)
         && (!("generatorOptions" in data) || data.generatorOptions is map)
         && (!("updatedAt" in data) || data.updatedAt is number);
    }

    match /users/{userId} {
      match /items/{itemId} {
        allow read: if isOwner(userId) && isValidId(itemId) && existing().userId == request.auth.uid;
        allow list: if isOwner(userId) && resource.data.userId == request.auth.uid;
        allow create: if isOwner(userId) && isValidId(itemId) && isValidBlobDoc(incoming());
        allow update: if isOwner(userId) && isValidId(itemId) && isValidBlobDoc(incoming()) && incoming().userId == existing().userId;
        allow delete: if isOwner(userId) && isValidId(itemId) && existing().userId == request.auth.uid;
      }

      match /folders/{folderId} {
        allow read: if isOwner(userId) && isValidId(folderId) && existing().userId == request.auth.uid;
        allow list: if isOwner(userId) && resource.data.userId == request.auth.uid;
        allow create: if isOwner(userId) && isValidId(folderId) && isValidBlobDoc(incoming());
        allow update: if isOwner(userId) && isValidId(folderId) && isValidBlobDoc(incoming()) && incoming().userId == existing().userId;
        allow delete: if isOwner(userId) && isValidId(folderId) && existing().userId == request.auth.uid;
      }

      match /maskedEmails/{emailId} {
        allow read: if isOwner(userId) && isValidId(emailId) && existing().userId == request.auth.uid;
        allow list: if isOwner(userId) && resource.data.userId == request.auth.uid;
        allow create: if isOwner(userId) && isValidId(emailId) && isValidBlobDoc(incoming());
        allow update: if isOwner(userId) && isValidId(emailId) && isValidBlobDoc(incoming()) && incoming().userId == existing().userId;
        allow delete: if isOwner(userId) && isValidId(emailId) && existing().userId == request.auth.uid;
      }

      match /settings/private {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidUserSettings(incoming());
        allow update: if isOwner(userId) && isValidUserSettings(incoming());
        allow delete: if isOwner(userId);
      }
    }
  }
}
